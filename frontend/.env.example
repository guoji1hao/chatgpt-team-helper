# 前端本地 Docker / localhost 环境变量样板
# 当前项目推荐通过 Nginx 统一入口访问：http://localhost:5173
# 在 Docker Desktop 本地构建场景下，VITE_API_URL 请保持为空，
# 这样前端会自动使用相对路径 /api。

# 留空（推荐）
VITE_API_URL=

# Cloudflare Turnstile 站点密钥（可选）
VITE_TURNSTILE_SITE_KEY=

# Turnstile 小部件尺寸（可选）
# 默认 invisible，也可选 managed / compact / normal / flexible
VITE_TURNSTILE_WIDGET_SIZE=invisible
